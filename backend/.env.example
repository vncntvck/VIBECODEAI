# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Session secret — ganti dengan string random panjang
SESSION_SECRET=ganti_dengan_random_string_panjang_minimal_32_karakter

# Google OAuth2 (dari Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-app.railway.app/api/gmail/callback

# URL frontend (untuk CORS)
FRONTEND_URL=https://your-frontend.railway.app

# Port (Railway set otomatis)
PORT=3000